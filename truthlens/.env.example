# Couchbase Configuration
# Copy this to .env and update values for your environment

# Enable/disable Couchbase (true to use, false to use in-memory storage)
USE_COUCHBASE=false

# Couchbase connection
COUCHBASE_HOST=couchbase://localhost
COUCHBASE_BUCKET=truthlens
COUCHBASE_USER=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_SCOPE=_default

# Connection options
COUCHBASE_TIMEOUT=5000
COUCHBASE_MAX_RETRIES=3

# Application
DEBUG=true
LOG_LEVEL=INFO

# Couchbase portal (TypeScript) configuration
# When true, backend.logic.store will use the TypeScript portal for persistence.
# When false (default), the backend uses in-memory storage (useful for tests).
USE_PORTAL=false

# Base URL for the TypeScript Couchbase portal HTTP API.
# Example when running the portal locally on port 3000:
#   http://localhost:3000/api
COUCHBASE_PORTAL_URL=http://localhost:3000/api

# HTTP timeout (in seconds) for calls from Python to the portal.
PORTAL_TIMEOUT_SECONDS=5.0
